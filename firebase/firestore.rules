rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminPath(storeId) {
      return /databases/$(database)/documents/stores/$(storeId)/admins/$(request.auth.uid);
    }

    function isStoreAdmin(storeId) {
      return isSignedIn() && exists(adminPath(storeId));
    }

    function isSafeText(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function isValidPeriod(value) {
      return value == 'daily' || value == 'weekly' || value == 'monthly';
    }

    function isValidItemStatus(value) {
      return value == 'checked' || value == 'unchecked';
    }

    function isValidUpdatedAt(value) {
      return isSafeText(value, 40) || value == request.time;
    }

    function isValidTaskData(data) {
      return data.keys().hasOnly([
          'id',
          'title',
          'description',
          'period',
          'sortOrder',
          'isActive',
          'createdAt',
          'updatedAt'
        ])
        && isSafeText(data.id, 120)
        && isSafeText(data.title, 120)
        && isSafeText(data.description, 500)
        && isValidPeriod(data.period)
        && data.sortOrder is number
        && data.isActive is bool;
    }

    function isValidTemplateData(data) {
      return data.keys().hasOnly([
          'id',
          'name',
          'period',
          'isActive',
          'createdAt',
          'updatedAt'
        ])
        && isSafeText(data.id, 120)
        && isSafeText(data.name, 120)
        && isValidPeriod(data.period)
        && data.isActive is bool;
    }

    function isValidTemplateItemData(data) {
      return data.keys().hasOnly([
          'taskId',
          'sortOrder',
          'isActive',
          'createdAt',
          'updatedAt'
        ])
        && isSafeText(data.taskId, 120)
        && data.sortOrder is number
        && data.isActive is bool;
    }

    function isValidRunData(storeId, targetDate, data) {
      return data.keys().hasOnly([
          'id',
          'storeId',
          'targetDate',
          'templateId',
          'storeName',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && data.id == targetDate
        && data.storeId == storeId
        && data.targetDate == targetDate
        && (!data.keys().hasAny(['templateId']) || isSafeText(data.templateId, 120))
        && (!data.keys().hasAny(['storeName']) || isSafeText(data.storeName, 120))
        && isSafeText(data.status, 40);
    }

    function isValidRunItemData(data) {
      return data.keys().hasOnly([
          'id',
          'templateItemId',
          'title',
          'description',
          'period',
          'sortOrder',
          'status',
          'checkedBy',
          'checkedByUserId',
          'checkedAt',
          'updatedAt',
          'isActive'
        ])
        && isSafeText(data.id, 120)
        && isSafeText(data.templateItemId, 120)
        && isSafeText(data.title, 120)
        && isSafeText(data.description, 500)
        && isValidPeriod(data.period)
        && data.sortOrder is number
        && isValidItemStatus(data.status)
        && isSafeText(data.checkedBy, 80)
        && isSafeText(data.checkedByUserId, 128)
        && isSafeText(data.checkedAt, 40)
        && isValidUpdatedAt(data.updatedAt)
        && data.isActive is bool;
    }

    function isValidEmployeeItemUpdate() {
      let data = request.resource.data;
      let before = resource.data;
      return data.diff(before).affectedKeys().hasOnly([
          'status',
          'checkedBy',
          'checkedByUserId',
          'checkedAt',
          'updatedAt'
        ])
        && isValidRunItemData(data)
        && (
          (data.status == 'checked'
            && data.checkedBy != ''
            && data.checkedByUserId == request.auth.uid
            && data.checkedAt != '')
          || (data.status == 'unchecked'
            && data.checkedBy == ''
            && data.checkedByUserId == ''
            && data.checkedAt == '')
        );
    }

    function isValidUserProfile(uid, data) {
      return uid == request.auth.uid
        && data.keys().hasOnly([
          'uid',
          'liffUserId',
          'displayName',
          'updatedAt',
          'lastSeenAt'
        ])
        && data.uid == uid
        && isSafeText(data.liffUserId, 128)
        && isSafeText(data.displayName, 120);
    }

    function isValidChecklistEvent(storeId, targetDate) {
      let data = request.resource.data;
      return isSignedIn()
        && data.keys().hasOnly([
          'runId',
          'targetDate',
          'storeId',
          'itemId',
          'status',
          'checkedBy',
          'checkedByUserId',
          'checkedAt',
          'updatedAt',
          'sourceUserId',
          'sourceClientId',
          'emittedAt'
        ])
        && data.storeId == storeId
        && data.targetDate == targetDate
        && isSafeText(data.runId, 80)
        && isSafeText(data.itemId, 120)
        && isValidItemStatus(data.status)
        && isSafeText(data.checkedBy, 80)
        && isSafeText(data.checkedByUserId, 128)
        && isSafeText(data.checkedAt, 40)
        && data.updatedAt == request.time
        && data.sourceUserId == request.auth.uid
        && isSafeText(data.sourceClientId, 128)
        && data.sourceClientId != ''
        && data.emittedAt == request.time
        && (
          (data.status == 'checked'
            && data.checkedBy != ''
            && data.checkedByUserId == data.sourceUserId
            && data.checkedAt != '')
          || (data.status == 'unchecked'
            && data.checkedBy == ''
            && data.checkedByUserId == ''
            && data.checkedAt == '')
        );
    }

    function isValidTemplateInsertEvent(storeId, targetDate) {
      let data = request.resource.data;
      return isStoreAdmin(storeId)
        && data.keys().hasOnly([
          'type',
          'runId',
          'targetDate',
          'storeId',
          'templateId',
          'period',
          'items',
          'sourceUserId',
          'sourceClientId',
          'emittedAt'
        ])
        && data.type == 'template_insert'
        && data.storeId == storeId
        && data.targetDate == targetDate
        && (!data.keys().hasAny(['runId']) || isSafeText(data.runId, 80))
        && isSafeText(data.templateId, 120)
        && isValidPeriod(data.period)
        && data.items is list
        && data.items.size() > 0
        && data.items.size() <= 30
        && data.sourceUserId == request.auth.uid
        && isSafeText(data.sourceClientId, 128)
        && data.sourceClientId != ''
        && data.emittedAt == request.time;
    }

    function isValidItemDeleteEvent(storeId, targetDate) {
      let data = request.resource.data;
      return isStoreAdmin(storeId)
        && data.keys().hasOnly([
          'type',
          'runId',
          'targetDate',
          'storeId',
          'itemId',
          'updatedAt',
          'sourceUserId',
          'sourceClientId',
          'emittedAt'
        ])
        && data.type == 'item_delete'
        && data.storeId == storeId
        && data.targetDate == targetDate
        && (!data.keys().hasAny(['runId']) || isSafeText(data.runId, 80))
        && isSafeText(data.itemId, 120)
        && data.updatedAt == request.time
        && data.sourceUserId == request.auth.uid
        && isSafeText(data.sourceClientId, 128)
        && data.sourceClientId != ''
        && data.emittedAt == request.time;
    }

    match /stores/{storeId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /admins/{uid} {
        allow read: if isStoreAdmin(storeId);
        allow write: if false;
      }

      match /users/{uid} {
        allow read: if isStoreAdmin(storeId) || (isSignedIn() && uid == request.auth.uid);
        allow create, update: if isSignedIn() && isValidUserProfile(uid, request.resource.data);
        allow delete: if false;
      }

      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow create, update: if isStoreAdmin(storeId) && isValidTaskData(request.resource.data);
        allow delete: if false;
      }

      match /templates/{templateId} {
        allow read: if isSignedIn();
        allow create, update: if isStoreAdmin(storeId) && isValidTemplateData(request.resource.data);
        allow delete: if false;

        match /items/{itemId} {
          allow read: if isSignedIn();
          allow create, update: if isStoreAdmin(storeId) && isValidTemplateItemData(request.resource.data);
          allow delete: if false;
        }
      }

      match /runs/{targetDate} {
        allow read: if isSignedIn();
        allow create, update: if isStoreAdmin(storeId) && isValidRunData(storeId, targetDate, request.resource.data);
        allow delete: if false;

        match /items/{itemId} {
          allow read: if isSignedIn();
          allow create: if isStoreAdmin(storeId) && isValidRunItemData(request.resource.data);
          allow update: if (isStoreAdmin(storeId) && isValidRunItemData(request.resource.data))
            || (isSignedIn() && isValidEmployeeItemUpdate());
          allow delete: if false;
        }

        match /events/{eventId} {
          allow read: if isSignedIn();
          allow create: if isValidChecklistEvent(storeId, targetDate)
            || isValidTemplateInsertEvent(storeId, targetDate)
            || isValidItemDeleteEvent(storeId, targetDate);
          allow update, delete: if false;
        }

        match /snapshots/{snapshotId} {
          allow read: if isSignedIn() && snapshotId == 'today';
          allow write: if false;
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
