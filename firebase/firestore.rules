rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /stores/{storeId}/runs/{targetDate}/events/{eventId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /stores/{storeId}/runs/{targetDate}/snapshots/{snapshotId} {
      allow read: if snapshotId == 'today';
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
