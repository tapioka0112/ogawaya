rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /stores/{storeId}/runs/{targetDate}/events/{eventId} {
      allow read: if true;
      allow create: if isValidEvent(storeId, targetDate);
      allow update, delete: if false;
    }

    match /stores/{storeId}/runs/{targetDate}/snapshots/{snapshotId} {
      allow read: if true;
      allow create, update: if isValidSnapshot(storeId, targetDate, snapshotId);
      allow delete: if false;
    }

    match /stores/{storeId}/monthly_stats/{monthId} {
      allow read: if true;
      allow write: if false;
    }

    match /stores/{storeId}/daily_stats/{targetDate} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isValidEvent(storeId, targetDate) {
    let requiredKeys = [
      'runId',
      'targetDate',
      'storeId',
      'itemId',
      'status',
      'checkedBy',
      'checkedByUserId',
      'checkedAt',
      'sourceUserId',
      'emittedAt'
    ];

    return request.resource.data.keys().hasAll(requiredKeys)
      && request.resource.data.keys().hasOnly(requiredKeys)
      && request.resource.data.storeId is string
      && request.resource.data.targetDate is string
      && request.resource.data.runId is string
      && request.resource.data.itemId is string
      && request.resource.data.status is string
      && request.resource.data.checkedBy is string
      && request.resource.data.checkedByUserId is string
      && request.resource.data.checkedAt is string
      && request.resource.data.sourceUserId is string
      && request.resource.data.emittedAt is timestamp
      && request.resource.data.storeId == storeId
      && request.resource.data.targetDate == targetDate
      && request.resource.data.status in ['checked', 'unchecked']
      && request.resource.data.storeId.matches('^[A-Za-z0-9_-]{1,64}$')
      && request.resource.data.targetDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
      && request.resource.data.runId.size() > 0
      && request.resource.data.runId.size() <= 128
      && request.resource.data.itemId.size() > 0
      && request.resource.data.itemId.size() <= 128
      && request.resource.data.checkedBy.size() <= 100
      && request.resource.data.checkedByUserId.size() <= 128
      && request.resource.data.checkedAt.size() <= 40
      && request.resource.data.sourceUserId.size() <= 128;
  }

  function isValidSnapshot(storeId, targetDate, snapshotId) {
    let requiredKeys = [
      'runId',
      'templateId',
      'storeName',
      'targetDate',
      'status',
      'currentUser',
      'progress',
      'items',
      'updatedAt'
    ];

    return snapshotId == 'today'
      && request.resource.data.keys().hasAll(requiredKeys)
      && request.resource.data.keys().hasOnly(requiredKeys)
      && request.resource.data.runId is string
      && request.resource.data.templateId is string
      && request.resource.data.storeName is string
      && request.resource.data.targetDate is string
      && request.resource.data.status is string
      && request.resource.data.currentUser is map
      && request.resource.data.currentUser.userId is string
      && request.resource.data.currentUser.name is string
      && request.resource.data.currentUser.role is string
      && request.resource.data.currentUser.store is map
      && request.resource.data.currentUser.store.id is string
      && request.resource.data.currentUser.store.name is string
      && request.resource.data.currentUser.store.id == storeId
      && request.resource.data.progress is map
      && request.resource.data.progress.checked is number
      && request.resource.data.progress.total is number
      && request.resource.data.items is list
      && request.resource.data.items.size() <= 400
      && request.resource.data.updatedAt is timestamp
      && request.resource.data.targetDate == targetDate
      && request.resource.data.storeName.size() <= 100
      && request.resource.data.status in ['open', 'closed']
      && request.resource.data.currentUser.store.id.matches('^[A-Za-z0-9_-]{1,64}$')
      && request.resource.data.targetDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
      && request.resource.data.runId.size() > 0
      && request.resource.data.runId.size() <= 128
      && request.resource.data.templateId.size() > 0
      && request.resource.data.templateId.size() <= 128;
  }
}
