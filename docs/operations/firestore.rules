rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSafeText(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function isValidItemStatus(value) {
      return value == 'checked' || value == 'unchecked';
    }

    function isValidChecklistEvent(storeId, targetDate) {
      let data = request.resource.data;
      return isSignedIn()
        && data.keys().hasOnly([
          'runId',
          'targetDate',
          'storeId',
          'itemId',
          'status',
          'checkedBy',
          'checkedByUserId',
          'checkedAt',
          'updatedAt',
          'sourceUserId',
          'emittedAt'
        ])
        && data.storeId == storeId
        && data.targetDate == targetDate
        && isSafeText(data.runId, 80)
        && isSafeText(data.itemId, 120)
        && isValidItemStatus(data.status)
        && isSafeText(data.checkedBy, 80)
        && isSafeText(data.checkedByUserId, 128)
        && isSafeText(data.checkedAt, 40)
        && data.updatedAt == request.time
        && isSafeText(data.sourceUserId, 128)
        && data.sourceUserId != ''
        && data.emittedAt == request.time
        && (
          (data.status == 'checked'
            && data.checkedBy != ''
            && data.checkedByUserId == data.sourceUserId
            && data.checkedAt != '')
          || (data.status == 'unchecked'
            && data.checkedBy == ''
            && data.checkedByUserId == ''
            && data.checkedAt == '')
        );
    }

    function isValidTemplateInsertEvent(storeId, targetDate) {
      let data = request.resource.data;
      return isSignedIn()
        && data.keys().hasOnly([
          'type',
          'runId',
          'targetDate',
          'storeId',
          'templateId',
          'items',
          'sourceUserId',
          'emittedAt'
        ])
        && data.type == 'template_insert'
        && data.storeId == storeId
        && data.targetDate == targetDate
        && isSafeText(data.runId, 80)
        && isSafeText(data.templateId, 120)
        && data.items is list
        && data.items.size() > 0
        && data.items.size() <= 30
        && isSafeText(data.sourceUserId, 128)
        && data.sourceUserId != ''
        && data.emittedAt == request.time;
    }

    match /stores/{storeId}/runs/{targetDate}/events/{eventId} {
      allow read: if true;
      allow create: if isValidChecklistEvent(storeId, targetDate) || isValidTemplateInsertEvent(storeId, targetDate);
      allow update, delete: if false;
    }

    match /stores/{storeId}/runs/{targetDate}/snapshots/{snapshotId} {
      allow read: if snapshotId == 'today';
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
